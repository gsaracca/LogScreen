@page "/operation/{OperationId}"
@layout AppLayout
@rendermode InteractiveServer
@inject _.Services.OperationTreeService TreeService

<PageTitle>@_title</PageTitle>

@if (_operation is null)
{
    <MudAlert Severity="Severity.Warning">Operación no encontrada: @OperationId</MudAlert>
}
else
{
    <div class="d-flex align-center mb-4">
        <MudIcon Icon="@_operation.Icon" Size="Size.Large" Color="Color.Primary" Class="mr-3" />
        <MudText Typo="Typo.h5">@_operation.Name</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.Circle">
            En ejecución
        </MudChip>
    </div>

    <MudDivider Class="mb-6" />

    <!-- Placeholder — aquí irá el contenido real de la DLL -->
    <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="0"
              Style="min-height:400px; border: 2px dashed var(--mud-palette-divider);">
        <MudIcon Icon="@Icons.Material.Filled.Extension" Size="Size.Large"
                 Style="font-size:64px; opacity:.2;" Class="mb-4" />
        <MudText Typo="Typo.h6" Color="Color.Secondary">@_operation.Name</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            El contenido de esta operación se cargará desde su DLL correspondiente.
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-1">
            ID: @OperationId
        </MudText>
    </MudPaper>
}

@code {
    [Parameter] public string OperationId { get; set; } = "";

    _.Models.OperationNode? _operation;
    string _title = "Operación";

    protected override void OnParametersSet()
    {
        _operation = TreeService.FindById(Uri.UnescapeDataString(OperationId));
        _title = _operation?.Name ?? "Operación";
    }
}
